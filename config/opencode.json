{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@warp-dot-dev/opencode-warp"],
  "agent": {
    "build": {
      "color": "#eab308"
    }
  },
  "permission": {
    "external_directory": {
      "~/Library/Application Support/rtk/tee/**": "allow"
    },
    "edit": {
      "~/Library/Application Support/rtk/tee/**": "deny"
    }
  },
  "provider": {
    "openrouter": {
      "models": {
        "z-ai/glm-4.7": {
          "options": {
            "provider": {
              "sort": "throughput"
            }
          }
        }
      }
    }
  }
}
